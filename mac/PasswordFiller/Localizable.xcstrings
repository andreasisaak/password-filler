      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Password Filler füllt HTTP-Basic-Auth-Dialoge in Chrome, Firefox, Brave und Safari automatisch mit Einträgen aus deinem 1Password-Tresor. Der Einrichtungsassistent führt dich in wenigen Schritten durch die Erstkonfiguration."
          }
        }
      }
    },
